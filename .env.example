# ── Supabase (public keys are safe to expose)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Admin (keep secret, only needed server-side or admin pages)
VITE_SUPER_ADMIN=admin@example.com

# ── Sentry (optional, leave empty in development)
VITE_SENTRY_DSN=
